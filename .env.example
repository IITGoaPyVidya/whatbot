# ─────────────────────────────────────────────
# WhatsApp AI Bot — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit the real .env file!
# ─────────────────────────────────────────────

# Google Gemini API key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (used as fallback if Gemini fails)
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional overrides ────────────────────────

# Gemini model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Custom system prompt for the bot's personality
# SYSTEM_PROMPT=You are a helpful and friendly WhatsApp assistant.

# Max tokens in each LLM response (default: 512)
# MAX_TOKENS=512
