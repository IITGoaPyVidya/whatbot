# ─── LLM API Keys ───────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── LLM Settings ───────────────────────────────────────────────────
# Which provider to use by default: "gemini" | "groq" | "auto"
# "auto" will round-robin between Gemini and Groq on each message
LLM_PROVIDER=auto

# Google Gemini model name (free tier supports these)
GEMINI_MODEL=gemini-1.5-flash

# Groq model name (free tier supports these)
GROQ_MODEL=llama3-8b-8192

# ─── Bot Settings ────────────────────────────────────────────────────
# Optional: restrict the bot to respond only when this prefix is used
# Leave empty to respond to every message
BOT_PREFIX=!bot

# Optional: allow bot to reply to group messages (true/false)
RESPOND_IN_GROUPS=false

# System prompt sent to the LLM for every conversation
SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Keep your answers short and clear.
